    Instance.new("UICorner", Tog).CornerRadius = UDim.new(1,0)
    local Ball = Instance.new("Frame", Tog)
    Ball.BackgroundColor3 = Color3.fromRGB(160,160,165); Ball.Position = UDim2.new(0,3,0.5,-7); Ball.Size = UDim2.new(0,14,0,14)
    Instance.new("UICorner", Ball).CornerRadius = UDim.new(1,0)
    local State = false
    Tog.MouseButton1Click:Connect(function()
        State = not State
        Tog.BackgroundColor3 = State and Color3.fromRGB(130,80,200) or Color3.fromRGB(45,45,50)
        Ball.Position = State and UDim2.new(1,-17,0.5,-7) or UDim2.new(0,3,0.5,-7)
        cb(State)
    end)
end

