local function MakeHL(obj, col, hlName)
    if not obj:FindFirstChild(hlName) then
        local hl = Instance.new("Highlight", obj); hl.Name = hlName; hl.FillColor = col; hl.FillTransparency = 0.4; hl.OutlineColor = col; hl.OutlineTransparency = 0
    end
end

task.spawn(function()
    while true do task.wait(0.5)
        if MonOn then
            for _, o in pairs(workspace:GetDescendants()) do
                if o:IsA("Model") and (o.Name:lower():find("monster") or o.Name:lower():find("bot") or o:FindFirstChild("HumanoidRootPart")) and o.Name ~= LP.Name and not o:IsDescendantOf(LP.Character) then
                    MakeHL(o, Color3.fromRGB(255,0,0), "PetaESP")
                end
            end
        end
        if ItemOn then
            for _, v in pairs(workspace:GetDescendants()) do
                if v:IsA("Model") or v:IsA("BasePart") then
                    local n = v.Name:lower()
                    if n:find("ofuda") or n:find("bua") then MakeHL(v, Color3.fromRGB(175, 215, 0), "ItemHL")
                    elseif n:find("chest") or n:find("ruong") or (n:find("box") and not n:find("ofuda")) then MakeHL(v, Color3.fromRGB(255, 120, 0), "ItemHL")
                    elseif n:find("safe") or n:find("ket") then MakeHL(v, Color3.fromRGB(10, 10, 10), "ItemHL")
                    elseif n:find("key") or n:find("llao") then MakeHL(v, Color3.fromRGB(130, 130, 135), "ItemHL")
                    elseif n:find("code") or n:find("matma") or n:find("paper") then MakeHL(v, Color3.fromRGB(255, 0, 0), "ItemHL")
                    elseif n:find("tool") or n:find("item") or n:find("giay") or v:IsA("Tool") then MakeHL(v, Color3.fromRGB(255, 215, 0), "ItemHL") end
                end
            end
        end
        if FastOpen then
            for _, p in pairs(workspace:GetDescendants()) do
                if p:IsA("ProximityPrompt") then p.HoldDuration = 0 end
            end
        end
    end
end)

task.spawn(function() while true do task.wait(0.1) if SpeedOn and LP.Character and LP.Character:FindFirstChildOfClass("Humanoid") then pcall(function() LP.Character:FindFirstChildOfClass("Humanoid").WalkSpeed = TargetSpeed end) end end end)

