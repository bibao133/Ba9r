-- ENGINE LOGIC ĐA NĂNG
local Plrs = game:GetService("Players")
local LP = Plrs.LocalPlayer
local Cam = workspace.CurrentCamera

local function IsHeadVisible(part)
    if not LP.Character then return false end
    local castParams = RaycastParams.new()
    castParams.FilterType = Enum.RaycastFilterType.Exclude
    
    local ignoreList = {LP.Character, Cam}
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") and (obj.Transparency > 0.8 or obj.CanCollide == false) then
            table.insert(ignoreList, obj)
        end
    end
    castParams.FilterDescendantsInstances = ignoreList
    
    local startPos = Cam.CFrame.Position
    local dir = (part.Position - startPos)
    local res = workspace:Raycast(startPos, dir, castParams)
    
    return res and res.Instance:IsDescendantOf(part.Parent) or false
end

local function GetTarget()
    local target, close = nil, math.huge
    local centerScreen = Vector2.new(Cam.ViewportSize.X / 2, Cam.ViewportSize.Y / 2)
    
    for _, p in pairs(Plrs:GetPlayers()) do
        if p ~= LP and p.Character and p.Character:FindFirstChild("Head") and p.Character:FindFirstChildOfClass("Humanoid") and p.Character.Humanoid.Health > 0 then
            local head = p.Character.Head
            local screenPos, onScreen = Cam:WorldToViewportPoint(head.Position)
            if onScreen then
                local d = (Vector2.new(screenPos.X, screenPos.Y) - centerScreen).Magnitude
                if d < (_G.FovRadius * 5.5) and d < close and IsHeadVisible(head) then
                    target, close = head, d
                end
            end
        end
    end
    return target
end

local function ApplyUniversalEsp(p)
    if p == LP then return end
    
    local function SetupCharacter(char)
        if not char then return end
        char:WaitForChild("Humanoid", 5)
        
        local hl = char:FindFirstChild("EspHighlight") or Instance.new("Highlight")
        hl.Name = "EspHighlight"
        hl.Parent = char
        hl.FillColor = Color3.fromRGB(255, 0, 0)
        hl.FillTransparency = 0.5
        hl.OutlineColor = Color3.fromRGB(255, 0, 0)
        hl.OutlineTransparency = 0
        hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        hl.Enabled = _G.EspActive
        
        local gui = char:FindFirstChild("EspNameGui") or Instance.new("BillboardGui")
        gui.Name = "EspNameGui"
        gui.Parent = char
        gui.AlwaysOnTop = true
        gui.Size = UDim2.new(0, 150, 0, 30)
        gui.StudsOffset = Vector3.new(0, 3.5, 0)
        gui.Enabled = _G.EspActive
        
        local lbl = gui:FindFirstChild("TextLabel") or Instance.new("TextLabel", gui)
        lbl.BackgroundTransparency = 1
        lbl.Size = UDim2.new(1, 0, 1, 0)
        lbl.Text = p.Name
        lbl.TextColor3 = Color3.fromRGB(255, 255, 255)
        lbl.TextSize = 13 lbl.Font = Enum.Font.SourceSansBold
        lbl.TextStrokeTransparency = 0
    end
    
    if p.Character then SetupCharacter(p.Character) end
    p.CharacterAdded:Connect(SetupCharacter)
end

for _, p in pairs(Plrs:GetPlayers()) do ApplyUniversalEsp(p) end
Plrs.PlayerAdded:Connect(ApplyUniversalEsp)

game:GetService("RunService").RenderStepped:Connect(function()
    if _G.FovVisible then
        local c = _G.RainbowFov and Color3.fromHSV(tick() % 3 / 3, 1, 1) or Color3.fromRGB(255, 0, 0)
        for _, dot in ipairs(FovDots) do dot.BackgroundColor3 = c end
    end
    
    if _G.AimActive then
        local t = GetTarget()
        if t then 
            local dir = (t.Position - Cam.CFrame.Position)
            if dir.Magnitude > 0.1 then Cam.CFrame = CFrame.new(Cam.CFrame.Position, t.Position) end
        end
    end
    
    for _, p in pairs(Plrs:GetPlayers()) do
        if p.Character then
            local hl = p.Character:FindFirstChild("EspHighlight")
            local gui = p.Character:FindFirstChild("EspNameGui")
            if hl then hl.Enabled = _G.EspActive end
            if gui then gui.Enabled = _G.EspActive end
        end
    end
end)
