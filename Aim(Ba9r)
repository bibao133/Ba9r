FovContainer.BackgroundTransparency = 1
FovContainer.Visible = false

local FovDots = {}
for i = 1, 150 do
    local dot = Instance.new("Frame", FovContainer)
    dot.BorderSizePixel = 0
    dot.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
    dot.Size = UDim2.fromOffset(2, 2)
    FovDots[i] = dot
end

local function UpdateFovDots()
    local r = _G.FovRadius * 5.5
    FovContainer.Size = UDim2.fromOffset(r * 2, r * 2)
    for i, dot in ipairs(FovDots) do
        local angle = (i / 150) * math.pi * 2
        dot.Position = UDim2.new(
            0.5 + math.cos(angle) * 0.5, 0,
            0.5 + math.sin(angle) * 0.5, 0
        )
    end
end
UpdateFovDots()

